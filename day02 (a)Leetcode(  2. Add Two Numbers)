# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def addTwoNumbers(self, l1: Optional[ListNode], l2: Optional[ListNode]) -> Optional[ListNode]:
         head = ListNode(0)
         temp = head
         carry =0
         while l1 or l2:
            x=0
            y=0
            if l1:
                x=l1.val
                l1=l1.next
            if l2:
                y= l2.val
                l2=l2.next
            s= x+y+carry

            carry = s//10
            temp.next = ListNode(s%10)
            temp = temp.next

         if carry:
            temp.next =ListNode(carry)

         return head.next

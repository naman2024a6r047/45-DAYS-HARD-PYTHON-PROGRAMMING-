class Solution:
    def romanToInt(self, s: str) -> int:
        roman ={
            "I":1,
            "V":5,
            "X":10,
            "L":50,
            "C":100,
            "D":500,
            "M":1000
        }
        count=0
        lis=[]
        for num in s :
            lis.append(roman[num])

        for i in range(len(s)-1):
            if lis[i] < lis[i+1]:
                count -= lis[i]
            else:
                count += lis[i]

        count += lis[-1]

        return count

            

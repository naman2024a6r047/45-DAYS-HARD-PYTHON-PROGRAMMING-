class Solution:
    def isValid(self, s: str) -> bool:
        stack = []
        mapping = {')':'(', '}':'{', ']':'['}
        
        for b in s:
            if b in mapping.values():  
                stack.append(b)
            else:
                if not stack or stack[-1] != mapping[b]:
                    return False
                stack.pop()
        
        return not stack
